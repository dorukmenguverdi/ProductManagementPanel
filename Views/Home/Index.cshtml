@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-5 fw-bold text-dark mb-3"><i class="bi bi-display me-2"></i>Yönetim Paneline Hoş Geldiniz
            </h1>
            <p class="lead text-muted mb-5">Sistem operasyonlarını, ürün stoklarını ve kullanıcı yetkilerini bu panel
                üzerinden güvenle yönetebilirsiniz.</p>
            </div>
        </div>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div class="row justify-content-center gap-4">
            </div>
        }
        else
        {
            <div class="row justify-content-center mt-5">
                <div class="col-md-6 text-center">
                    <div class="alert alert-secondary shadow-sm rounded-4 border-0 p-5">
                        <i class="bi bi-shield-lock display-1 text-secondary mb-3 d-block"></i>
                        <h4 class="fw-bold">Erişim Kısıtlı</h4>
                        <p class="text-muted mb-4">Paneli görüntülemek ve işlemlere başlamak için sisteme giriş yapmanız
                            gerekmektedir.</p>
                            <a href="/Auth/Login" class="btn btn-primary rounded-pill px-4 me-2">Giriş Yap</a>
                            <a href="/Auth/Register" class="btn btn-outline-primary rounded-pill px-4">Kayıt Ol</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-5">
                <div class="card shadow-sm border-0 h-100 rounded-4">
                    <div class="card-body text-center p-5">
                        <i class="bi bi-people display-4 text-success mb-3"></i>
                        <h3 class="card-title fw-bold">Kullanıcılar</h3>
                        <p class="card-text text-muted">Sisteme kayıtlı personelleri yönet, yetkilendir veya sistemden uzaklaştır.
                        </p>
                        <a href="/User/Index" class="btn btn-success px-4 rounded-pill">Kullanıcıları Yönet</a>
                    </div>
                </div>
            </div>
        }
    </div>
    }
</div>