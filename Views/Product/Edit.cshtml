@model ProductManagementPanel.Models.Product

@{
    ViewData["Title"] = "Ürün Güncelle";
}

<div class="container mt-4">
    <h2>Ürün Güncelle</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label">Ürün Adı</label>
                    @if (User.IsInRole("Personel"))
                    {
                        <input asp-for="Name" class="form-control" readonly />
                    }
                    else
                    {
                        <input asp-for="Name" class="form-control" />
                    }
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Fiyat</label>
                    @if (User.IsInRole("Personel"))
                    {
                        <input asp-for="Price" type="number" step="0.01" class="form-control" readonly />
                    }
                    else
                    {
                        <input asp-for="Price" type="number" step="0.01" class="form-control" />
                    }
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Stok</label>
                    <input asp-for="Stock" type="number" class="form-control" />
                </div>

                <button type="submit" class="btn btn-warning">Güncelle</button>
                <a href="/Product/Index" class="btn btn-secondary">İptal</a>
            </form>
        </div>
    </div>
</div>